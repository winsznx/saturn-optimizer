# Dependencies and generated output
.cache/
coverage/
node_modules/
dist/
build/
tmp/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor noise
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Next.js and Vercel artifacts
.next/
out/
.vercel/
apps/web/.next/
apps/web/out/
apps/web/build/
.eslintcache

# Environment files and local secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.local

# Keystore / Crypto (Saturn Optimizer)
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.der
*.secret
*.secrets
*.seed
*.mnemonic
*.keystore
*.keystore.json
wallet.json
accounts.json

# Clarinet and local deployment state
.clarinet/
deployments/*.simnet-plan.yaml
deployments/*.devnet-plan.yaml
deployments/*.testnet-plan.yaml

# Use local overrides for anything that may contain mnemonics, private keys,
# RPC credentials, or machine-specific deployment settings.
settings/*.toml
!settings/*.example.toml
settings/*.local.toml
settings/*.private.toml
settings/*.secrets.toml
settings/*-local.toml

# App / keeper local runtime config
apps/web/.env*
!apps/web/.env.example
scripts/keeper/.env*
chainhooks/*.local.json
packages/
saturnsdk/
