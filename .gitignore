# Dependencies and generated output
.cache/
coverage/
node_modules/
dist/
tmp/
*.log

# OS / editor noise
.DS_Store
*.swp
*.swo

# Environment files and local secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template

*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.der
*.secret
*.secrets
*.seed
*.mnemonic
*.keystore
*.keystore.json
wallet.json
accounts.json

# Clarinet and local deployment state
.clarinet/
deployments/*.simnet-plan.yaml
deployments/*.devnet-plan.yaml
deployments/*.testnet-plan.yaml

# Use local overrides for anything that may contain mnemonics, private keys,
# RPC credentials, or machine-specific deployment settings.
settings/*.toml
!settings/*.example.toml
settings/*.local.toml
settings/*.private.toml
settings/*.secrets.toml
settings/*-local.toml

# App / keeper local runtime config
apps/web/.env*
scripts/keeper/.env*
chainhooks/*.local.json
